{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "noImplicitAny": true,
        "strictNullChecks": true,
        "noEmit": true,
        "skipLibCheck": true,
        "allowImportingTsExtensions": true
    },
    "include": ["src/**/*.ts"]
}
