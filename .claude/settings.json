{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const d=JSON.parse(require('fs').readFileSync(0,'utf8'));const f=(d.tool_input||{}).file_path||'';if(f.endsWith('.ts')){const {execSync}=require('child_process');try{execSync('npx biome check \\\"'+f+'\\\"',{cwd:'D:/dev/crawlers',stdio:'inherit'});}catch(e){}try{execSync('npx tsc --noEmit',{cwd:'D:/dev/crawlers',stdio:'inherit'});}catch(e){}}\"",
            "statusMessage": "Running Biome + tsc..."
          }
        ]
      }
    ]
  }
}
